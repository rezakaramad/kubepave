# ---------------------------------------------------
# Terraform / OpenTofu state (NEVER commit plaintext)
# ---------------------------------------------------
*.tfstate
*.tfstate.*
*.tfvars
*.tfvars.json

# ---------------------------------------------------
# Allow encrypted state files
# ---------------------------------------------------
!*.tfstate.gpg

# ---------------------------------------------------
# Terraform working directory
# ---------------------------------------------------
.terraform/
.terraform.lock.hcl

# ---------------------------------------------------
# Plan files
# ---------------------------------------------------
*.tfplan
*.plan

# ---------------------------------------------------
# Crash logs
# ---------------------------------------------------
crash.log

# ---------------------------------------------------
# CLI config files
# ---------------------------------------------------
.terraformrc
terraform.rc

# ---------------------------------------------------
# Environment / secrets
# ---------------------------------------------------
.env
.env.*

# ---------------------------------------------------
# OS / Editor junk
# ---------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
